---
layout: base.njk
pageTitle: "CCSU LLB Syllabus — All 6 Semesters | Last Minute Law"
pageDescription: "Complete CCSU LLB 3-Year syllabus for all 6 semesters with paper codes, marks, optional subjects, and practical training details."
permalink: "/syllabus/"
---
<div class="detail-hero">
  <div class="wrap">
    <div class="breadcrumb"><a href="/">Home</a><span class="breadcrumb-sep">/</span><span>Syllabus</span></div>
    <div class="section-kicker">Curriculum</div>
    <h1 class="serif" style="font-size:clamp(32px,5vw,48px);line-height:1.0;">CCSU LLB Syllabus</h1>
    <p style="font-size:14px;color:var(--ink-60);margin-top:8px;">LL.B. 3 Year (Six Semester) · w.e.f. 2014-15 · Ch. Charan Singh University, Meerut</p>
  </div>
</div>
<div class="wrap" style="padding-bottom:60px;">
  {%- for semNum, sem in syllabus %}
  <div id="sem-{{ semNum }}" style="margin-bottom:40px;">
    <h2 class="serif" style="font-size:24px;margin-bottom:16px;padding-bottom:8px;border-bottom:2px solid var(--red);">{{ sem.name }} <span class="mono" style="font-size:14px;color:var(--ink-40);">· 500 Marks</span></h2>
    {%- for sub in sem.subjects %}
    <div style="display:grid;grid-template-columns:80px 1fr auto;gap:12px;padding:10px 0;border-bottom:1px solid var(--rule);align-items:center;font-size:14px;">
      <span class="mono" style="color:var(--red);font-size:12px;">{{ sub.code }}</span>
      <span>{{ sub.name }}
        {%- if sub.optional %} <span class="chip" style="font-size:10px;">Optional</span>{%- endif %}
        {%- if sub.practical %} <span class="chip chip--green" style="font-size:10px;">Practical</span>{%- endif %}
      </span>
      <span class="mono" style="font-size:12px;color:var(--ink-40);">{{ sub.marks }} marks</span>
    </div>
    {%- if sub.practicalNote %}<div style="padding-left:80px;font-size:12px;color:var(--ink-40);margin-bottom:8px;">{{ sub.practicalNote }}</div>{%- endif %}
    {%- endfor %}
  </div>
  {%- endfor %}
</div>
